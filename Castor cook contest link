<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <title>Castor Cook Contest</title>
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Poppins&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to right, #ff9966, #ff5e62);
      text-align: center;
      color: white;
      margin: 0;
      padding: 0;
    }

    h1 {
      font-family: 'Pacifico', cursive;
      font-size: 50px;
      margin-top: 40px;
    }

    .container {
      display: flex;
      justify-content: center;
      gap: 40px;
      margin-top: 50px;
      flex-wrap: wrap;
    }

    .card {
      background: white;
      color: black;
      padding: 20px;
      border-radius: 15px;
      width: 250px;
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .price {
      font-size: 22px;
      font-weight: bold;
      margin: 10px 0;
    }

    button {
      background: #ff5e62;
      color: white;
      border: none;
      padding: 10px 15px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 16px;
    }

    button:hover {
      background: #ff9966;
    }

    .message {
      margin-top: 30px;
      font-size: 20px;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <h1>Castor Cook Contest</h1>

  <div class="container">
    
    <div class="card">
      <h2>Toeschouwer</h2>
      <div class="price">€2</div>
      <p>Je kijkt naar de kook contest</p>
      <button onclick="koop()">Koop ticket</button>
    </div>

    <div class="card">
      <h2>Meedoen</h2>
      <div class="price">€10</div>
      <p>Je doet mee en neemt je eigen barbecue mee</p>
      <button onclick="koop()">Koop ticket</button>
    </div>

  </div>

  <div class="message" id="bericht"></div>

  <script>
    function koop() {
      document.getElementById("bericht").innerText = "Bedankt voor je aankoop!";
    }
  </script>

</body>
</html>
