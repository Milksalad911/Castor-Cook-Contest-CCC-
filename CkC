<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <title>Castor Cook Contest</title>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      text-align: center;
      background: #1a1a1a;
      color: #ffffff;
    }

    h1 {
      font-size: 3rem;
      margin-top: 40px;
      font-weight: 800;
    }

    .nav {
      margin-top: 20px;
    }

    .nav button {
      margin: 5px;
    }

    .cards {
      display: flex;
      justify-content: center;
      gap: 30px;
      margin-top: 50px;
      flex-wrap: wrap;
    }

    .card {
      background: #242424;
      width: 280px;
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      transition: 0.3s ease;
    }

    .card:hover {
      transform: scale(1.05);
    }

    .price {
      font-size: 1.4rem;
      color: #FFD700;
      margin: 10px 0;
      font-weight: 700;
    }

    button {
      background: #ff5e62;
      border: none;
      padding: 12px 20px;
      color: white;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
    }

    button:hover {
      background: #ff3b3b;
    }

    .overlay {
      position: fixed;
      top:0; left:0;
      width:100%;
      height:100%;
      background:rgba(0,0,0,0.8);
      display: none;
      align-items: center;
      justify-content: center;
    }

    .popup {
      background: #222;
      padding: 30px;
      width: 320px;
      border-radius: 12px;
    }

    .popup input {
      width: 90%;
      padding: 10px;
      margin: 8px 0;
      border-radius: 6px;
      border: none;
    }

    .section {
      display: none;
    }

    .active {
      display: block;
    }

    .about {
      max-width: 600px;
      margin: 50px auto;
      background: #242424;
      padding: 30px;
      border-radius: 12px;
    }
  </style>
</head>
<body>

<h1>Castor Cook Contest</h1>

<div class="nav">
  <button onclick="showSection('home')">Home</button>
  <button onclick="showSection('about')">Over dit evenement</button>
</div>

<!-- HOME -->
<div id="home" class="section active">
  <div class="cards">
    <div class="card">
      <h2>Toeschouwer</h2>
      <div class="price">€2</div>
      <p>Je kijkt naar de kook contest</p>
      <button onclick="openPay('Toeschouwer', 2)">KIES</button>
    </div>

    <div class="card">
      <h2>Meedoen</h2>
      <div class="price">€10</div>
      <p>Je doet mee en neemt je eigen barbecue mee</p>
      <button onclick="openPay('Meedoen', 10)">KIES</button>
    </div>
  </div>
</div>

<!-- ABOUT -->
<div id="about" class="section">
  <div class="about">
    <h2>Over dit evenement</h2>
    <p>
      Dit evenement is een kookevent dat plaatsvindt op 23 april 2026.<br><br>
      Iedereen neemt zijn eigen barbecue mee. Pannen en hittematerialen worden meegegeven.<br><br>
      Messen en andere kookmiddelen worden ook gegeven.<br><br>
      Draag stevige schoenen en dichte kleren.<br><br>
      Zie jullie daar!
    </p>
  </div>
</div>

<!-- BETALING -->
<div class="overlay" id="overlay">
  <div class="popup">
    <h3 id="payTitle"></h3>

    <div id="formSection">
      <input placeholder="Naam">
      <input placeholder="Kaartnummer">
      <input placeholder="MM/JJ">
      <input placeholder="CVC">
      <button onclick="confirmPay()">Betaal</button>
    </div>

    <div id="thanksSection" style="display:none;">
      <h3>✅ Bedankt voor je aankoop!</h3>
    </div>

    <button onclick="closePopup()">Sluiten</button>
  </div>
</div>

<script>
function openPay(type, price) {
  document.getElementById('overlay').style.display = 'flex';
  document.getElementById('payTitle').innerText =
    `Betalen: ${type} (€${price})`;

  document.getElementById('formSection').style.display = 'block';
  document.getElementById('thanksSection').style.display = 'none';
}

function confirmPay() {
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('thanksSection').style.display = 'block';
}

function closePopup() {
  document.getElementById('overlay').style.display = 'none';
}

function showSection(section) {
  document.getElementById('home').classList.remove('active');
  document.getElementById('about').classList.remove('active');
  document.getElementById(section).classList.add('active');
}
</script>

</body>
</html>
